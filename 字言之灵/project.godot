config_version=5

[application]

config/name="字言之灵"
config/version="2026.0.1"
run/main_scene="uid://mqrujlphhxuh"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://dcjannm2bvcw2"
driver/enable_input=true

[autoload]

